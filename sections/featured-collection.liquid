<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: #F1EFE8;
    color: #1A1A18;
    -webkit-font-smoothing: antialiased;
  }

  /* ─── SECTION ─── */
  .section {
    max-width: 1280px;
    margin: 0 auto;
    padding: 80px 40px;
  }

  /* ─── HEADER ─── */
  .section-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 1px solid #D3D1C7;
  }

  .section-header__left { display: flex; flex-direction: column; gap: 6px; }

  .eyebrow {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #888780;
    font-weight: 400;
  }

  .section-title {
    font-family: 'DM Serif Display', serif;
    font-size: 40px;
    font-weight: 400;
    line-height: 1.05;
    color: #1A1A18;
  }

  .section-title em {
    font-style: italic;
    color: #888780;
  }

  .view-all {
    font-size: 14px;
    color: #888780;
    text-decoration: none;
    border-bottom: 1px solid #D3D1C7;
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
    margin-bottom: 6px;
  }

  .view-all:hover { color: #1A1A18; border-color: #1A1A18; }

  /* ─── FILTERS ─── */
  .filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .chip {
    font-size: 13px;
    font-family: 'DM Sans', sans-serif;
    padding: 7px 18px;
    border-radius: 100px;
    border: 1px solid #D3D1C7;
    color: #888780;
    background: #fff;
    cursor: pointer;
    transition: all 0.15s;
  }

  .chip.active { background: #1A1A18; color: #fff; border-color: #1A1A18; }
  .chip:hover:not(.active) { border-color: #888780; color: #1A1A18; }

  /* ─── GRID ─── */
  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  @media (max-width: 1024px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) { .grid { grid-template-columns: 1fr; } .section { padding: 48px 20px; } .section-title { font-size: 28px; } }

  /* ─── CARD ─── */
  .card {
    background: #fff;
    border-radius: 14px;
    border: 1px solid #E8E6DF;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.2s, transform 0.25s cubic-bezier(.22,.68,0,1.2), box-shadow 0.25s;
    position: relative;
  }

  .card:hover {
    border-color: #B4B2A9;
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.07);
  }

  /* image */
  .card__img {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
  }

  .card__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
    display: block;
  }

  .card:hover .card__img img { transform: scale(1.04); }

  .card__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card__img-placeholder svg { width: 48px; height: 48px; opacity: 0.2; }

  .img--gray    { background: #D3D1C7; }
  .img--purple  { background: linear-gradient(145deg, #CECBF6, #AFA9EC); }
  .img--teal    { background: linear-gradient(145deg, #9FE1CB, #5DCAA5); }
  .img--coral   { background: linear-gradient(145deg, #F5C4B3, #F0997B); }

  /* badge */
  .badge {
    position: absolute;
    top: 12px;
    left: 12px;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 4px;
    z-index: 2;
  }

  .badge--new  { background: #1A1A18; color: #F1EFE8; }
  .badge--sale { background: #D85A30; color: #FAECE7; }
  .badge--low  { background: #FAC775; color: #633806; }

  /* wishlist */
  .wishlist {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    background: #fff;
    border: 1px solid #E8E6DF;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 0.2s, transform 0.2s;
    z-index: 3;
  }

  .card:hover .wishlist { opacity: 1; transform: scale(1); }
  .wishlist:hover { border-color: #888780; }
  .wishlist svg { width: 15px; height: 15px; stroke: #888780; fill: none; stroke-width: 1.5; }

  /* add to cart */
  .add-btn {
    position: absolute;
    bottom: 12px;
    left: 12px;
    right: 12px;
    background: rgba(255,255,255,0.95);
    backdrop-filter: blur(4px);
    border: 1px solid #E8E6DF;
    border-radius: 8px;
    padding: 10px;
    font-size: 13px;
    font-weight: 500;
    font-family: 'DM Sans', sans-serif;
    color: #1A1A18;
    cursor: pointer;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.2s, transform 0.2s, background 0.15s;
    z-index: 3;
    letter-spacing: 0.02em;
  }

  .card:hover .add-btn { opacity: 1; transform: translateY(0); }
  .add-btn:hover { background: #1A1A18; color: #fff; border-color: #1A1A18; }
  .add-btn:active { transform: translateY(1px); }

  /* card body */
  .card__body { padding: 14px 16px 16px; }

  .card__meta {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 8px;
  }

  .card__name {
    font-size: 14px;
    font-weight: 500;
    color: #1A1A18;
    line-height: 1.3;
  }

  .card__sub {
    font-size: 12px;
    color: #888780;
    font-weight: 400;
    margin-top: 2px;
  }

  .card__price { text-align: right; white-space: nowrap; }

  .price-current { font-size: 14px; font-weight: 500; color: #1A1A18; display: block; }

  .price-old {
    font-size: 12px;
    color: #B4B2A9;
    text-decoration: line-through;
    font-weight: 400;
    display: block;
  }

  /* swatches */
  .swatches { display: flex; gap: 6px; margin-bottom: 10px; }

  .swatch {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    cursor: pointer;
    transition: transform 0.15s;
    border: 1.5px solid transparent;
    outline: 1.5px solid transparent;
    outline-offset: 1px;
  }

  .swatch:hover { transform: scale(1.15); }
  .swatch.active { outline-color: #888780; }
  .swatch--white { border-color: #D3D1C7; }

  /* rating */
  .rating { display: flex; align-items: center; gap: 5px; }

  .stars { display: flex; gap: 2px; }
  .star { width: 12px; height: 12px; }
  .star--filled { fill: #BA7517; }
  .star--empty  { fill: #D3D1C7; }

  .rating-count { font-size: 12px; color: #B4B2A9; }
</style>


